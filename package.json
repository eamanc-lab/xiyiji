{
  "name": "xiyiji",
  "version": "30.0.0",
  "description": "AI Digital Human Video Synthesis Platform",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-win.ps1",
    "release": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-release.ps1",
    "release:full": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-release.ps1 --full",
    "release:customer": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-release.ps1 --full --customer-sample",
    "release:update": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-update-package.ps1",
    "postinstall": "electron-builder install-app-deps",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "electron-log": "^5.2.4",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "pinia": "^2.3.0",
    "sql.js": "^1.11.0",
    "tdesign-vue-next": "^1.10.5",
    "uuid": "^11.0.5",
    "vue": "^3.5.13",
    "vue-i18n": "^9.14.0",
    "vue-router": "^4.5.0",
    "wavesurfer.js": "^7.8.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "javascript-obfuscator": "^5.3.0",
    "rollup-plugin-obfuscator": "^1.1.0",
    "terser": "^5.46.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.0",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.2.0"
  },
  "build": {
    "appId": "com.xiyiji.app",
    "productName": "云映数字人",
    "asar": true,
    "afterPack": "./scripts/protect-asar.js",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/"
      }
    ]
  }
}
